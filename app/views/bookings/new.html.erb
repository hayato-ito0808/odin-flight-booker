<h1>予約者情報</h1>
<%= form_with model: @booking do |f| %>
    <%= f.fields_for :passengers do |ff| %>
        <p>
            <%= ff.label :name, "氏名" %>
            <%= ff.text_field :name %>
        </p>
        <p>
            <%= ff.label :email, "メールアドレス" %>
            <%= ff.text_field :email %>
        </p>
        

        
    <% end %>
    <%= f.hidden_field :flight_id, value: params[:flight_id] %>
    <%= f.submit %>
<% end %>
